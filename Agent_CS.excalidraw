    {
      "id": "vm7thYzXfueIR2Mf3dF0Q",
      "type": "text",
      "x": -4424.766420603477,
      "y": 6278.15916571333,
      "width": 1603.5453043861276,
      "height": 670.7622403560802,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bAV",
      "roundness": null,
      "seed": 2082024003,
      "version": 309,
      "versionNonce": 1863203971,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1773798139185,
      "link": null,
      "locked": false,
      "text": "For MVP\n- Messages carry a classification label field (the data type\nexists)\n- Agent registry has a clearance field (the data type exists)\n- Transport checks label against clearance before delivery\n(the enforcement point exists)\n- Everything in the MVP is internal or below, so the check\nalways passes\n- No sensitive data, no sanitizing process, no air lock, no\nRBAC integration",
      "fontSize": 53.66097922848641,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "For MVP\n- Messages carry a classification label field (the data type exists)\n- Agent registry has a clearance field (the data type exists)\n- Transport checks label against clearance before delivery (the enforcement point exists)\n- Everything in the MVP is internal or below, so the check always passes\n- No sensitive data, no sanitizing process, no air lock, no RBAC integration",
      "autoResize": false,
      "lineHeight": 1.25
    },
