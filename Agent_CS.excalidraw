      "roundness": null,
      "seed": 2041198147,
      "version": 342,
      "versionNonce": 884961507,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1773796363079,
      "link": null,
      "locked": false,
      "text": "Protocol — agent knows its\nprofile, provides good UX,\ntells human when something\nrequires the harness",
      "fontSize": 27.47504237804581,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
