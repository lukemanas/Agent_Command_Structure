    {
      "id": "usrqbXFWj5wRF7YY_JXfw",
      "type": "text",
      "x": -1001.1866214424717,
      "y": 8858.28197301713,
      "width": 687.680497278852,
      "height": 325,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bDT",
      "roundness": null,
      "seed": 900604845,
      "version": 737,
      "versionNonce": 1028105261,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1773802435540,
      "link": null,
      "locked": false,
      "text": "SOW Data Structure:\n\nSOW {\nproject_title:        string    (required)\nobjective:            string    (required)\nproject_id:           string    (required, unique)\nrisk_classification:  enum      (required, human-set: low | high)\ncollaborator_ids:     []string  (optional)\ncontext:              []string  (optional)\n}\n\n- Validation fails → error, tells human what's missing, nothing happens\n- Validation passes → project container created",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "SOW Data Structure:\n\nSOW {\nproject_title:        string    (required)\nobjective:            string    (required)\nproject_id:           string    (required, unique)\nrisk_classification:  enum      (required, human-set: low | high)\ncollaborator_ids:     []string  (optional)\ncontext:              []string  (optional)\n}\n\n- Validation fails → error, tells human what's missing, nothing happens\n- Validation passes → project container created",
      "autoResize": false,
      "lineHeight": 1.25
    },
