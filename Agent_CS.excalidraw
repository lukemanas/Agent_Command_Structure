      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "9fq5Q7_Ut0J3laIF7NFXF",
      "type": "text",
      "x": -1746.160683196219,
      "y": 8223.904866377661,
      "width": 1251.3807769105094,
      "height": 205.84631822080976,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bCQ",
      "roundness": null,
      "seed": 91150819,
      "version": 813,
      "versionNonce": 1466671053,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1773802435540,
      "link": null,
      "locked": false,
      "text": "The personal agent drafts or the human provides a SOW. Either way the\nagent presents it back for confirmation.\n\nLightweight by default — can be a 1 minute conversation.\n",
      "fontSize": 32.935410915329555,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "The personal agent drafts or the human provides a SOW. Either way the agent presents it back for confirmation.\n\nLightweight by default — can be a 1 minute conversation.\n",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "BsZebPdKvT_5BU9I1nPuZ",
      "type": "text",
      "x": -3053.0982166806025,
      "y": 8739.600156260125,
      "width": 364.4414688400602,
      "height": 150,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bCR",
      "roundness": null,
      "seed": 977683789,
      "version": 385,
      "versionNonce": 2111839789,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1773802435540,
      "link": null,
      "locked": false,
      "text": "Trigger: The human asks their\npersonal agent (analyst) to do\nsomething that requires execution.\nThe agent recognizes this crosses\nthe cognition/execution boundary\nand initiates the SOW process.",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Trigger: The human asks their personal agent (analyst) to do something that requires execution. The agent recognizes this crosses the cognition/execution boundary and initiates the SOW process.",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "fFooLhPUVd-WbFEY6jmZB",
      "type": "rectangle",
      "x": -3108.150230824279,
      "y": 8707.558567692013,
      "width": 466.89590426962604,
      "height": 233.54569044426898,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
