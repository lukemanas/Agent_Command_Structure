    {
      "id": "-A_a4sDrEVUOqVICX9nNB",
      "type": "text",
      "x": -146.2999127629614,
      "y": 9372.983291242988,
      "width": 791.6865936169044,
      "height": 238.23298602208163,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bCp",
      "roundness": null,
      "seed": 2064248589,
      "version": 726,
      "versionNonce": 291911405,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1773802435540,
      "link": null,
      "locked": false,
      "text": "Context Preparation:\n\nThe personal agent gathers and packages starting context into the project\ncontainer. For high risk, this is the only data agents will have access to.\n\n- Low risk: agents can read outside the container, context links are\nreferences\n- High risk: data is replicated into the container at initiation, agents only\nhave keys for the container",
      "fontSize": 21.176265424185036,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Context Preparation:\n\nThe personal agent gathers and packages starting context into the project container. For high risk, this is the only data agents will have access to.\n\n- Low risk: agents can read outside the container, context links are references\n- High risk: data is replicated into the container at initiation, agents only have keys for the container",
      "autoResize": false,
      "lineHeight": 1.25
    },
