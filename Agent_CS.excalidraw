      "containerId": null,
      "originalText": "Launches Harness",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "SoWPFHuFEz8WLTs1huNrI",
      "type": "text",
      "x": -1251.0734220789107,
      "y": 2441.1751102886838,
      "width": 1299.3488677679595,
      "height": 86.15046058673619,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b69",
      "roundness": null,
      "seed": 522969178,
      "version": 4391,
      "versionNonce": 559476931,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1773796363079,
      "link": null,
      "locked": false,
      "text": "The user has full access to tools and the major benefits of the harness, but with clearly bounded roles between\naction. User initiates the project and launches the harness (the equivalent is launching Claude Code) Personal\nagent gathers and prepares starting context for the handoff to inter-project agents",
      "fontSize": 22.973456156462984,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "The user has full access to tools and the major benefits of the harness, but with clearly bounded roles between action. User initiates the project and launches the harness (the equivalent is launching Claude Code) Personal agent gathers and prepares starting context for the handoff to inter-project agents",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "QPyEi7cHO7FUwFKVa1A8m",
