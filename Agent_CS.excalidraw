      "y": 2456.7156992755413,
      "width": 395.8369140625,
      "height": 54.679647428432425,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
